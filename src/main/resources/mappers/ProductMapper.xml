<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.demo.mappers.ProductMapper">

    <select id="selectAllNames" resultType="java.lang.String">
        SELECT name FROM product
    </select>

    <select id="findByUserId" resultType="com.example.demo.model.Product">
        SELECT * FROM product WHERE user_id = #{userId}
    </select>

</mapper>